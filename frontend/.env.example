VITE_CESIUM_TOKEN=
VITE_SOVEREIGN_PROXY_URL=https://api.sovdefence.local/proxy
VITE_MARITIME_WS_URL=ws://localhost:8001/ws/maritime

# UC4 — bbox for client-side filtering hints. The authoritative subscription
# bbox lives in the platform ConfigMap (configmap-common.yaml:AIS_BBOX_DEFAULT)
# and the multiplexer enforces it server-side; this VITE_ entry is provided
# for any future feature that wants to render bbox edges or send a per-client
# bbox query (?bbox_s=...&bbox_n=...) to the multiplexer.
VITE_MARITIME_BBOX=53,8,56,22
