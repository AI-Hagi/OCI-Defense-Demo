# AIS Multiplexer — example environment.
# Copy to .env (or symlink to repo-root .env) and fill in real OCIDs.
# NEVER commit .env.
#
# Variables already in the repo-root .env.example are NOT repeated here:
#   OCI_REGION, OCI_COMPARTMENT_OCID, OCI_PROFILE,
#   VAULT_AIS_STREAM_KEY_OCID, AIS_BBOX_DEFAULT
# Pydantic-settings reads them from the same .env, so define each variable
# in exactly one place — the repo-root .env. This template only documents
# the service-specific extras.

# --- Oracle 26ai ATP (service-specific connection) ---
ATP_CONNECTION_NAME=sovdef26_tp
ATP_USER=DICE_APP
ATP_PASSWORD=REPLACE_ME
TNS_ADMIN=/app/wallet
WALLET_PASSWORD=REPLACE_ME

# --- Multiplexer behaviour (service-specific) ---
MULTIPLEXER_PORT=8001

# Audit batching — service-specific tuning of the writes to audit_events.
AUDIT_FLUSH_FRAMES=50
AUDIT_FLUSH_SECONDS=10

# --- Local-dev only — bypasses OCI Vault. NEVER set in production. ---
# MOCK_VAULT_KEY=dummy-aisstream-key
