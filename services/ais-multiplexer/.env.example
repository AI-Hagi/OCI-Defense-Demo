# AIS Multiplexer — example environment.
# Copy to .env and fill in real OCIDs / credentials. NEVER commit .env.

# --- OCI Tenancy / Region ---
OCI_REGION=eu-frankfurt-1
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..REPLACE_WITH_OCI_DEFENCE_DEMO_OCID

# --- Vault — AIS Stream API key (Pattern B free-tier) ---
# This is the OCID of the secret in OCI Vault, NOT the secret value itself.
VAULT_AIS_STREAM_KEY_OCID=ocid1.vaultsecret.oc1..REPLACE_WITH_AIS_STREAM_KEY_OCID

# --- Oracle 26ai ATP ---
ATP_CONNECTION_NAME=sovdef26_tp
ATP_USER=DICE_APP
ATP_PASSWORD=REPLACE_ME
TNS_ADMIN=/app/wallet
WALLET_PASSWORD=REPLACE_ME

# --- Multiplexer behaviour ---
# Bbox = south,west,north,east (decimal degrees, WGS84).
# Default: Baltic Sea (53N..56N, 8E..22E).
AIS_BBOX_DEFAULT=53,8,56,22
MULTIPLEXER_PORT=8001

# Audit batching
AUDIT_FLUSH_FRAMES=50
AUDIT_FLUSH_SECONDS=10

# --- Local-dev only — bypasses OCI Vault. NEVER set in production. ---
# MOCK_VAULT_KEY=dummy-aisstream-key
